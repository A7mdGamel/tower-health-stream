# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5433

# Airflow
AIRFLOW__WEBSERVER__SECRET_KEY=tower-health-secret
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:29092

# Iceberg
ICEBERG_REST_URL=http://localhost:8182
ICEBERG_WAREHOUSE=/opt/iceberg/warehouse

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# dbt
DBT_PROFILES_DIR=~/.dbt
DBT_PROJECT_DIR=./dbt_project
DUCKDB_PATH=./data/tower_health.duckdb

# Open-Meteo (no API key required)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Simulator
SIMULATOR_TOWERS_FILE=./data/towers_clean.csv
SIMULATOR_INTERVAL_SECONDS=5
SIMULATOR_ANOMALY_RATE=0.05
